          <mxGeometry height="80" width="310" x="-135" y="590" as="geometry" />
        </mxCell>
        <mxCell id="pABJUcwdlSBN9XXVtCt0-7" parent="1" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;" value="" vertex="1">

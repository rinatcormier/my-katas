        <mxCell id="pABJUcwdlSBN9XXVtCt0-9" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontFamily=Courier New;fontSize=13;" value="Pure Java" vertex="1">
          <mxGeometry height="30" width="130" x="420" y="440" as="geometry" />
        </mxCell>
        <mxCell id="pABJUcwdlSBN9XXVtCt0-11" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontFamily=Courier New;fontSize=13;" value="Hexagonal Architecture" vertex="1">
          <mxGeometry height="40" width="200" x="390" y="470" as="geometry" />
        </mxCell>
        <mxCell id="pABJUcwdlSBN9XXVtCt0-13" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Courier New;fontSize=8;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;Гексагональная архитектура, за счёт изоляции от других компонентов системы, позволяет тестировать бизнес-логику чисто юнит-тестами. В идеале, абсолютно всё тестируется через юнит-тесты, даже логирование (тут стоит подумать, если логирование происходит на уровне интеграции или контроллера, то как тестить логирование? Этот вопрос был рассмотрен у Хорикова, в книге про тестирование.). Также, в идеале, бизнес логика должна быть ещё покрыта мутабельными тестами. Так как это Pure Java, то мутабельные тесты тут хорошо подходят.&lt;/span&gt;&lt;/h1&gt;" vertex="1">
          <mxGeometry height="230" width="520" x="680" y="250" as="geometry" />
        </mxCell>
        <mxCell id="pABJUcwdlSBN9XXVtCt0-14" edge="1" parent="1" style="endArrow=classic;html=1;rounded=0;" target="pABJUcwdlSBN9XXVtCt0-13" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="580" y="490" as="sourcePoint" />
            <mxPoint x="630" y="440" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="pABJUcwdlSBN9XXVtCt0-17" edge="1" parent="1" source="pABJUcwdlSBN9XXVtCt0-6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.471;entryY=1.022;entryDx=0;entryDy=0;entryPerimeter=0;" target="pABJUcwdlSBN9XXVtCt0-7">

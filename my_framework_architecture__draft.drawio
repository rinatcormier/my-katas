        </mxCell>
        <mxCell id="pABJUcwdlSBN9XXVtCt0-18" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Spring&#39;s Rest Controller" vertex="1">
          <mxGeometry height="30" width="170" x="45" y="410" as="geometry" />
        </mxCell>
        <mxCell id="pABJUcwdlSBN9XXVtCt0-19" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;Тестируется только средствами Spring для тестирования контроллеров&lt;/font&gt;&lt;/h1&gt;" vertex="1">
          <mxGeometry height="100" width="220" x="-260" y="500" as="geometry" />
        </mxCell>
        <mxCell id="pABJUcwdlSBN9XXVtCt0-21" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Интеграции с DB, Kafka etc." vertex="1">
          <mxGeometry height="30" width="280" x="750" y="690" as="geometry" />
        </mxCell>
        <mxCell id="pABJUcwdlSBN9XXVtCt0-22" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Тестируется через Spring Data Test + Testcontainers&lt;/font&gt;&lt;/h1&gt;" vertex="1">
          <mxGeometry height="50" width="340" x="880" y="840" as="geometry" />
        </mxCell>
        <mxCell id="pABJUcwdlSBN9XXVtCt0-25" edge="1" parent="1" source="pABJUcwdlSBN9XXVtCt0-24" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="pABJUcwdlSBN9XXVtCt0-4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pABJUcwdlSBN9XXVtCt0-24" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Spring Security (роли, пермиссии...)&lt;/h1&gt;" vertex="1">
          <mxGeometry height="50" width="430" x="290" y="140" as="geometry" />
        </mxCell>
        <mxCell id="pABJUcwdlSBN9XXVtCt0-26" edge="1" parent="1" source="pABJUcwdlSBN9XXVtCt0-24" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.54;entryY=0.013;entryDx=0;entryDy=0;entryPerimeter=0;" target="pABJUcwdlSBN9XXVtCt0-7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pABJUcwdlSBN9XXVtCt0-28" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Вешается на контроллеры или на бизнес-логику? Если второе, то это уже не Pure Java. Поэтому, предположительно, Spring Security вешается только на контроллеры.&lt;/font&gt;&lt;/h1&gt;" vertex="1">
          <mxGeometry height="100" width="320" x="160" y="240" as="geometry" />
        </mxCell>
        <mxCell id="pABJUcwdlSBN9XXVtCt0-29" edge="1" parent="1" source="pABJUcwdlSBN9XXVtCt0-28" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.248;entryY=0.867;entryDx=0;entryDy=0;entryPerimeter=0;" target="pABJUcwdlSBN9XXVtCt0-24">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="v74TKjIDD4j9ubcqONKH-6" edge="1" parent="1" source="v74TKjIDD4j9ubcqONKH-1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" target="v74TKjIDD4j9ubcqONKH-4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="v74TKjIDD4j9ubcqONKH-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="" vertex="1">
          <mxGeometry height="320" width="830" x="-1280" y="120" as="geometry" />
        </mxCell>
        <mxCell id="v74TKjIDD4j9ubcqONKH-3" edge="1" parent="1" source="v74TKjIDD4j9ubcqONKH-2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="pABJUcwdlSBN9XXVtCt0-2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="v74TKjIDD4j9ubcqONKH-2" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontSize=22;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;E2E тесты (REST API)&lt;/h1&gt;&lt;p&gt;Для прогона E2E тестов, сервис поднимается полностью (интеграции с БД, Kafka через Testcontainers, а с другими сервисами через Mock сервисы). Тестируется как black box, без опоры на знания внутренностей сервиса. Используется, например, RestAssured.&lt;/p&gt;" vertex="1">
          <mxGeometry height="260" width="750" x="-1230" y="150" as="geometry" />
        </mxCell>
        <mxCell id="v74TKjIDD4j9ubcqONKH-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="" vertex="1">
          <mxGeometry height="180" width="825" x="-1010" y="-410" as="geometry" />
        </mxCell>
        <mxCell id="v74TKjIDD4j9ubcqONKH-5" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontSize=20;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;font&gt;Allure&lt;/font&gt;&lt;/h1&gt;&lt;p&gt;&lt;font&gt;Все отчёты по прогнанным E2E тестам попадают в Allure, где хранятся какое-то время.&lt;/font&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="140" width="770" x="-975" y="-380" as="geometry" />
        </mxCell>
